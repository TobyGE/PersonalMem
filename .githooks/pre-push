#!/usr/bin/env bash
# PersonalMem pre-push hook — run `codex review` against the commits about
# to be pushed, surface findings BEFORE they hit the remote.
#
# Behaviour:
#   - Advisory only: never blocks the push (always exits 0).
#   - Skips when:
#       * the env var PERSONALMEM_SKIP_REVIEW=1 is set
#       * `codex` CLI isn't on PATH
#       * the push is a delete or no real ref change
#   - Reviews `${remote_sha}..${local_sha}` per ref being pushed.
#     For brand-new branches (no remote_sha), reviews the last 10 commits.
#
# Install once per fresh clone:
#     git config core.hooksPath .githooks
#
# Adapted from OpenSeer's pre-push hook.

set -u

if [[ "${PERSONALMEM_SKIP_REVIEW:-0}" == "1" ]]; then
    exit 0
fi

if ! command -v codex >/dev/null 2>&1; then
    echo "[pre-push] codex CLI not found, skipping review"
    exit 0
fi

ZERO="0000000000000000000000000000000000000000"

# stdin format per `git help hooks`:
#   <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r local_ref local_sha remote_ref remote_sha; do
    # delete branch: nothing to review
    [[ "$local_sha" == "$ZERO" ]] && continue
    # no change
    [[ "$local_sha" == "$remote_sha" ]] && continue

    if [[ "$remote_sha" == "$ZERO" ]]; then
        # Brand-new branch. We want diff = "all (up to 10) commits being
        # pushed". `base..HEAD` is exclusive of base, so use the parent of
        # the oldest selected commit. For a single-commit branch with no
        # parent (genesis), fall back to git's empty-tree sentinel so the
        # entire branch's content is included in the review diff.
        oldest="$(git rev-list --max-count=10 "$local_sha" | tail -n 1)"
        # `git rev-parse` (without --verify) prints the literal arg on
        # failure, so an invalid `oldest^` would still set base to a
        # bogus non-empty string. --verify suppresses output on failure
        # and exits non-zero.
        base="$(git rev-parse --verify "${oldest}^" 2>/dev/null || true)"
        if [ -z "${base:-}" ]; then
            base="$(git hash-object -t tree /dev/null)"   # empty tree
        fi
        scope="new branch — up to last 10 commits ending at $(git rev-parse --short "$local_sha")"
    else
        base="$remote_sha"
        scope="$(git rev-parse --short "$base")..$(git rev-parse --short "$local_sha")"
    fi

    echo
    echo "── pre-push: codex review ($scope) ──"
    if ! codex review --base "$base" \
            --title "pre-push: $(git rev-parse --abbrev-ref HEAD)" 2>&1; then
        echo "[pre-push] codex review exited non-zero — push continuing anyway"
    fi
done

echo
echo "── codex review done. Push? Ctrl+C to abort, anything else to continue. ──"
# `while read` above consumed git's hook stdin; read from the controlling
# terminal instead so the 10-second abort window actually exists. Wrap the
# whole thing in a block that swallows stderr so non-tty environments
# (Claude Code's bash, CI, certain editor terminals) don't spew
# "/dev/tty: Device not configured" — they just silently skip the prompt.
{
    read -r -t 10 _ < /dev/tty || true
} 2>/dev/null
exit 0
